# examples/apps.example.env
# ==============================================================================
# Environment Variables Configuration Example
# File naming convention: apps.<env>.env (e.g., apps.dev.env)
# ==============================================================================

# 1. LITERALS (KEY=VALUE)
# These are synchronized into a Kubernetes ConfigMap.
# Use for non-sensitive configuration data.
LOG_LEVEL=debug
DATABASE_NAME=orders_db
FEATURE_FLAG_NEW_UI=true
PORT=3000

# 2. PLACEHOLDERS (KEY=${VAR})
# These indicate that the value will be fetched from HashiCorp Vault.
# These keys are synchronized into a Kubernetes Secret.
# Use for credentials, tokens, and private keys.
DATABASE_PASSWORD=${DB_PASS}
STRIPE_SECRET_KEY=${STRIPE_API_TOKEN}
JWT_SECRET=${JWT_SIGNING_KEY}

# 3. COMMENTS & WHITESPACE
# Comments starting with '#' are ignored by the generator.
# Empty lines are also skipped.
