# projects/phoenix-project/variables.env
# Global configurations
DB_HOST=postgres.phoenix-project.svc.cluster.local
REDIS_URL=redis://cache.phoenix-project.svc.cluster.local:6379
LOG_LEVEL=info
GATEWAY_TIMEOUT=60s

# Secrets placeholders
DB_PASSWORD=${DB_PASSWORD}
JWT_SECRET=${JWT_SECRET}
STRIPE_API_KEY=${STRIPE_API_KEY}
